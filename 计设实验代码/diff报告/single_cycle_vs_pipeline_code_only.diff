+    check("x7", dut.U_PIPECPU.U_RF.rf[7], 32'h0000_1236);
+    check("x9", dut.U_PIPECPU.U_RF.rf[9], 32'h0000_000c);
+    check("x19", dut.U_PIPECPU.U_RF.rf[19], 32'h9876_3dcc);
