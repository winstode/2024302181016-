    %vpi_call/w 5 38 "$display", "[RESULT] pipe_sorted_sid=%h", v000001db7c289580_0 {0 0 0};
    %load/vec4 v000001db7c2898a0_0;
    %cmpi/e 0, 0, 32;
    %jmp/0xz  T_12.4, 4;
    %vpi_call/w 5 39 "$display", "[PASS] lab-6 pipeline sid sorting simulation passed." {0 0 0};
    %jmp T_12.5;
T_12.4 ;
